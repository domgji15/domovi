APP_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Option 1: complete PostgreSQL URL (recommended in production)
# DATABASE_URL=postgresql://domovi:domovi@127.0.0.1:5432/domovi

# Option 2: separate PostgreSQL variables (useful for docker-compose/local)
POSTGRES_DB=domovi
POSTGRES_USER=domovi
POSTGRES_PASSWORD=domovi
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# DB/HTTP hardening (recommended for production)
DB_CONN_MAX_AGE=60
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
USE_X_FORWARDED_PROTO=False

# Dev-only quick login
AUTO_LOGIN_ENABLED=False
# AUTO_LOGIN_USERNAME=admin
